# 공개 사이트 + /admin CMS 환경변수. 실제 값은 .env (gitignore됨)에 둔다.

# DB 파일 경로. 미설정 시 환경별 기본값: dev=./data/dev.db, prod=./data/blog.db.
# 부팅 시 자동 마이그레이션됨(수동 seed 없음). 컨테이너에선 PVC 경로로 덮어쓴다.
# DATABASE_URL=./data/dev.db

# ── /admin 인증 ──────────────────────────────────────────────
# 세션 쿠키 서명 키. 길고 랜덤한 문자열. (미설정 시 dev 전용 기본값 사용 → 운영에서 반드시 설정)
AUTH_SECRET=

# 어드민 비밀번호의 bcrypt 해시. (미설정 시 dev 전용 기본 비번 "duhyunkim" 통과)
# 생성: node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" '내비밀번호'
ADMIN_PASSWORD_HASH=
